#!/bin/bash
# Handles restore modes for Legacy/BIOS systems - Manjaro GRUB Rescue
# Modes: 1=Simple, 2=Intermediate, 3=Complete, 6=MHL, 7=Pamac, 8=Timeshift

set -e

export TEXTDOMAINDIR="/usr/share/locale"
export TEXTDOMAIN=manjaro-grub-rescue

log_message() { echo "$(date '+%Y-%m-%d %H:%M:%S'): $1" >&2; }
show_progress() { echo "PROGRESS: $1"; }
handle_error() { 
    log_message "ERROR: $1"
    umount -l /mnt 2>/dev/null || true
    echo "ERROR: $1" >&2
    exit "${2:-1}"
}

safe_mount() {
    local dev="$1"
    local target="$2"
    local opts="$3"
    
    log_message "Attempting to mount $dev on $target"
    mkdir -p "$target"
    
    if [ -n "$opts" ]; then
        mount "$dev" "$target" -o "$opts" || handle_error "Failed to mount $dev"
    else
        mount "$dev" "$target" || handle_error "Failed to mount $dev"
    fi
}

execute_chroot() {
    local cmd="$1"
    local desc="$2"
    log_message "Executing: $desc"
    show_progress "$desc"
    if ! echo "$cmd" | manjaro-chroot /mnt /bin/bash; then 
        handle_error "Failed during: $desc" 
    fi
}

log_message "Starting Legacy/BIOS GRUB restore"

[ ! -f /tmp/grub-disks-selected ] && handle_error "Boot disk selection not found."
[ ! -f /tmp/os-prober-selected ] && handle_error "System partition selection not found."

GRUB_DISK=$(cat /tmp/grub-disks-selected)
SELECTED_PARTITION=$(awk -F: '{ print $1 }' /tmp/os-prober-selected)
PARTITION_FORMAT=$(awk -F: '{ print $5 }' /tmp/os-prober-selected)
RESTORE_MODE=$(cat /tmp/grub-restore-apply-mode 2>/dev/null || echo "1")

show_progress "Preparing mount points..."

umount -l /mnt 2>/dev/null || true

if [ "$PARTITION_FORMAT" = "btrfs" ]; then
    safe_mount "$SELECTED_PARTITION" "/mnt" "subvol=@,defaults,compress=zstd"
else
    safe_mount "$SELECTED_PARTITION" "/mnt" "defaults"
fi

case "$RESTORE_MODE" in
    "1")
        log_message "Executing Simple Restore"
        execute_chroot "grub-install --target=i386-pc /dev/$GRUB_DISK --recheck" "Installing GRUB"
        execute_chroot "grub-mkconfig -o /boot/grub/grub.cfg" "Updating configuration"
        ;;
    "2")
        log_message "Executing Intermediate Restore"
        execute_chroot "rm -f /var/lib/pacman/db.lck" "Cleaning package lock"
        execute_chroot "pacman --noconfirm -Sy grub" "Reinstalling GRUB"
        execute_chroot "grub-install --target=i386-pc /dev/$GRUB_DISK --recheck" "Installing GRUB"
        execute_chroot "mkinitcpio -P" "Regenerating initramfs"
        execute_chroot "grub-mkconfig -o /boot/grub/grub.cfg" "Updating configuration"
        ;;
    "3")
        log_message "Executing Complete Restore"
        execute_chroot "rm -f /var/lib/pacman/db.lck" "Cleaning package lock"
        execute_chroot "pacman-key --init && pacman-key --populate archlinux manjaro" "Refreshing keys"
        execute_chroot "pacman --noconfirm -Syu" "Updating system"
        execute_chroot "pacman --noconfirm -S grub linux" "Installing core packages"
        execute_chroot "grub-install --target=i386-pc /dev/$GRUB_DISK --recheck" "Installing GRUB"
        execute_chroot "mkinitcpio -P" "Regenerating initramfs"
        execute_chroot "grub-mkconfig -o /boot/grub/grub.cfg" "Updating configuration"
        ;;
    "6")
        log_message "Opening MHL (Manjaro Hardware Lookup)"
        show_progress "Launching Manjaro Hardware Lookup..."
        execute_chroot "mlh" "MHL"
        ;;
    "7")
        log_message "Opening Pamac Package Manager"
        show_progress "Launching Pamac..."
        execute_chroot "rm -f /var/lib/pacman/db.lck" "Cleaning lock"
        execute_chroot "pamac-manager" "Pamac"
        ;;
    "8")
        log_message "Opening Timeshift"
        show_progress "Launching Timeshift..."
        if execute_chroot "command -v timeshift-gtk >/dev/null 2>&1 && timeshift-gtk" "Timeshift" 2>/dev/null; then
            :
        else
            execute_chroot "zenity --warning --text='Timeshift not installed'" "Warning"
        fi
        ;;
    *)
        handle_error "Invalid mode: $RESTORE_MODE"
        ;;
esac

show_progress "Finishing..."
sync
umount -l /mnt

log_message "Restore completed"
show_progress "Operation completed!"
exit 0