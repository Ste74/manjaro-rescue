msgstr  ""

msgid   "The boot in live mode is using EFI mode, but <span "
        "foreground='red'>I didn't find any EFI partition</span> on this "
        "computer,\n"
        "probably GRUB restoration will not work.\n"
        "\n"
        "Try to restart and through the computer BIOS make the boot in Legacy "
        "or BIOS mode.\n"
        "\n"
