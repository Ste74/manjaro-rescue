msgid ""
"Your computer is not connected to the internet, options 2 and 3 need "
"internet to work."
msgstr ""
"Your computer is not connected to the internet, options 2 and 3 need "
"internet to work."

msgid ""
"<span font='16' foreground='LightSkyBlue'>Select the desired option:</span>\n"
"        \n"
"Restoration can be done in 3 ways (<span foreground='gray'>Simple, "
"Intermediate or Complete</span>),if in doubt, try the first\n"
"option, restart the computer and see if you resolved.\n"
"\n"
"If the problem persists try the other options."
msgstr ""
"<span font='16' foreground='LightSkyBlue'>Select the desired option:</span>\n"
"        \n"
"Restoration can be done in 3 ways (<span foreground='gray'>Simple, "
"Intermediate or Complete</span>),if in doubt, try the first\n"
"option, restart the computer and see if you resolved.\n"
"\n"
"If the problem persists try the other options."

msgid "Option"
msgstr "Option"

msgid "Description"
msgstr "Description"

msgid "Simple, just record the grub again at the beginning of the disk."
msgstr "Simple, just record the grub again at the beginning of the disk."

msgid ""
"Intermediate, reinstalls the GRUB package in the partition, generates the "
"configuration and updates Initrd."
msgstr ""
"Intermediate, reinstalls the GRUB package in the partition, generates the "
"configuration and updates Initrd."

msgid ""
"Complete, performs the stages of the intermediate restoration, updates the "
"system and checks if the LTS kernel is installed."
msgstr ""
"Complete, performs the stages of the intermediate restoration, updates the "
"system and checks if the LTS kernel is installed."

msgid "Interactive, opens a terminal within the selected system."
msgstr "Interactive, opens a terminal within the selected system."

msgid "Interactive, opens a TUI control center within the selected system."
msgstr "Interactive, opens a TUI control center within the selected system."

msgid "Collect useful logs from installed system"
msgstr "Collect useful logs from installed system"

msgid "Interactive, opens the package manager within the selected system."
msgstr "Interactive, opens the package manager within the selected system."

msgid "Done!"
msgstr "Done!"

